{
	"name": "flowbite-svelte-starter",
	"version": "0.1.3",
	"description": "Flowbite-Svelte starter kit",
	"author": {
		"name": "Shinichi Okada",
		"email": "connect@codewithshin.com",
		"url": "https://blog.codewithshin.com"
	},
	"bugs": "https://github.com/shinokada/flowbite-svelte-starter/issues",
	"homepage": "https://github.com/shinokada/flowbite-svelte-starter",
	"license": "MIT",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"test": "playwright test",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:unit": "vitest",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@playwright/test": "^1.30.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"@tailwindcss/vite": "^4.0.0",
		"@typescript-eslint/eslint-plugin": "^8.0.0",
		"@typescript-eslint/parser": "^8.0.0",
		"eslint": "^9.0.0",
		"eslint-config-prettier": "^9.0.0",
		"eslint-plugin-svelte": "^2.0.0",
		"flowbite": "^3.0.0",
		"flowbite-svelte": "^1.0.0",
		"prettier": "^3.0.0",
		"prettier-plugin-svelte": "^3.0.0",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"tailwindcss": "^4.0.0",
		"tslib": "^2.5.0",
		"typescript": "^5.0.0",
		"vite": "^6.0.0",
		"vitest": "^2.0.0"
	},
	"type": "module",
	"keywords": [
		"svelte",
		"sveltekit",
		"flowbite",
		"flowbite-svelte",
		"tailwindcss"
	],
	"engines": {
		"npm": ">=7.0.0",
		"node": ">=18.0.0"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/shinokada/flowbite-svelte-starter.git"
	},
	"dependencies": {
		"@schedule-x/calendar": "^3.0.0",
		"@schedule-x/svelte": "3.0.0",
		"@schedule-x/theme-default": "^3.0.0",
		"dayjs": "^1.11.20",
		"flowbite-svelte-icons": "^2.0.0",
		"lucide-svelte": "^1.0.1",
		"temporal-polyfill": "0.3.0"
	}
}
